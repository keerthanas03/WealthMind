{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["displayName", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "UserProfile" },
      "description": "User profile document"
    }
  }
}
